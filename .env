# =============================================================================
# Symfony
# =============================================================================
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change-me-to-random-32-char-string
APP_SECURE_COOKIES=false
DEFAULT_URI=http://localhost:8080

# =============================================================================
# Docker user
# =============================================================================
APP_UID=1000
APP_GID=1000
TZ=UTC

# =============================================================================
# Exposed ports
# =============================================================================
APP_PORT=8080
RR_STATUS_PORT=2114
POSTGRES_PORT=5432
REDIS_PORT=6379
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=secret
POSTGRES_HOST=postgres
POSTGRES_INTERNAL_PORT=5432

# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=redis
REDIS_INTERNAL_PORT=6379
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=1

# =============================================================================
# JWT (ES256)
# =============================================================================
JWT_PRIVATE_KEY_PATH=/app/config/jwt/private.pem
JWT_PUBLIC_KEY_PATH=/app/config/jwt/public.pem
JWT_PASSPHRASE=change-me
JWT_ISSUER=kinodom
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=2592000

# =============================================================================
# Mailer
# =============================================================================
MAILER_HOST=mailpit
MAILER_PORT=1025
MAILER_FROM_ADDRESS=noreply@kinodom.ru
MAILER_FROM_NAME=Kinodom

# =============================================================================
# CORS
# =============================================================================
CORS_ALLOW_ORIGIN=*

# =============================================================================
# RoadRunner
# =============================================================================
RR_NUM_WORKERS=0
RR_MAX_JOBS=64
RR_MAX_WORKER_MEMORY=256
RR_EXEC_TTL=30s
RR_LOG_MODE=production
RR_LOG_LEVEL=warn

# =============================================================================
# Prod resource limits
# =============================================================================
APP_CPU_LIMIT=2
APP_MEMORY_LIMIT=512M
POSTGRES_MEMORY_LIMIT=256M
REDIS_MEMORY_LIMIT=128M

# =============================================================================
# Xdebug (dev only): off | debug | coverage | profile
# =============================================================================
XDEBUG_MODE=off
