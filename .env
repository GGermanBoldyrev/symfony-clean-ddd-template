# =============================================================================
# Symfony
# =============================================================================
APP_ENV=dev
APP_DEBUG=1
# Генерация: openssl rand -hex 16
APP_SECRET=change-me-to-random-32-char-string
DEFAULT_URI=http://localhost:8080

# =============================================================================
# Ports
# =============================================================================
APP_PORT=8080
RR_STATUS_PORT=2114
POSTGRES_PORT=5432
REDIS_PORT=6379
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=secret

# =============================================================================
# Database
# =============================================================================
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?serverVersion=18&charset=utf8"
MESSENGER_TRANSPORT_DSN="redis://redis:6379/messages"

# =============================================================================
# RoadRunner
# =============================================================================
RR_NUM_WORKERS=0
RR_MAX_JOBS=64
RR_MAX_WORKER_MEMORY=256
RR_EXEC_TTL=30s
RR_LOG_MODE=production
RR_LOG_LEVEL=warn

# =============================================================================
# CORS - для production
# =============================================================================
CORS_ALLOW_ORIGIN=*

# =============================================================================
# Timezone
# =============================================================================
TZ=UTC

# =============================================================================
# Docker user
# =============================================================================
APP_UID=1000
APP_GID=1000

# =============================================================================
# Prod resource limits
# =============================================================================
APP_CPU_LIMIT=2
APP_MEMORY_LIMIT=512M
POSTGRES_MEMORY_LIMIT=256M
REDIS_MEMORY_LIMIT=128M

# =============================================================================
# Xdebug (dev only): off | debug | coverage | profile
# =============================================================================
XDEBUG_MODE=off

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###
